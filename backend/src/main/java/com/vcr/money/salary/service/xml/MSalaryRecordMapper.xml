<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vcr.money.salary.service.mapper.MSalaryRecordMapper">

    <!-- 自定义查询示例：根据工资类型和完结状态统计金额 -->
    <select id="sumSalaryByTypeAndFinish" resultType="java.lang.String">
        SELECT SUM(CAST(salary AS DECIMAL(18,2)))
        FROM m_salary_record
        WHERE del_flag = 0
          AND salary_type = #{salaryType}
          AND is_finish = #{isFinish}
    </select>
</mapper>